# supportLegal - Environment Configuration

# LLM Keys
GEMINI_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_TOKEN=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
HF_TOKEN=

# Database
QDRANT_URL=http://localhost:6334
QDRANT_HOST=qdrant
QDRANT_PORT=6334
# local: SQLITE_DB_PATH=sqlite_data/legal_poc.db
SQLITE_DB_PATH=data/legal_poc.db
# Settings
EMBEDDING_MODEL_NAME=bkai-foundation-models/vietnamese-bi-encoder
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://support-legal-vn.vercel.app
# CLASSIFIER_PROVIDER=dashscope
# CLASSIFIER_FALLBACK_PROVIDER=ollama
# CLASSIFIER_MODEL=qwen-14b-chat
CLASSIFIER_PROVIDER=ollama
CLASSIFIER_FALLBACK_PROVIDER=ollama
CLASSIFIER_MODEL=qwen2.5:3b
CLASSIFIER_PROVIDER_TIMEOUT=20
GENERATION_PROVIDER=ollama
GENERATION_MODEL=qwen2.5:3b
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Indexing Config
BATCH_SIZE=256
CHUNK_SIZE=1000
CHUNK_OVERLAP=30
INDEX_CHUNKS=0

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://cent-indianapolis-towers-dad.trycloudflare.com
# config for local development
EMBEDDING_DEVICE=gpu