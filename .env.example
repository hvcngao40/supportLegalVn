# supportLegal - Environment Configuration

# LLM Keys (replace with real values in a private .env file or secret store)
GEMINI_API_KEY=
HUGGINGFACE_TOKEN=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Database
QDRANT_HOST=qdrant
QDRANT_PORT=6334
# Optional fallback only; canonical production contract uses QDRANT_HOST/QDRANT_PORT.
QDRANT_URL=

# Redis Cache Configuration (Phase 19)
REDIS_URL=redis://redis:6379
REDIS_DB=0
# Similarity threshold for Redis cache hits (0.0 to 1.0, default 0.95 = very strict)
REDIS_THRESHOLD=0.95
# Enable Redis vector search for semantic caching (default true if Redis available)
REDIS_ENABLED=true

SQLITE_DB_PATH=legal_poc.db

# Settings
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EMBEDDING_MODEL_NAME=bkai-foundation-models/vietnamese-bi-encoder
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/legal-api.jsonl

# LLM Generation Control (Phase 19)
# When false (DEFAULT), backend returns prompt+retrievals without calling LLM
# Frontend receives response and handles LLM call externally
ENABLE_LLM_GENERATION=false

CLASSIFIER_PROVIDER=deepseek
CLASSIFIER_FALLBACK_PROVIDER=gemini
CLASSIFIER_MODEL=deepseek-chat
CLASSIFIER_PROVIDER_TIMEOUT=20
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen-14b-chat
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=

# Generation Provider Selection
GENERATION_PROVIDER=groq
GENERATION_MODEL=llama-3.1-8b-instant

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://cent-indianapolis-towers-dad.trycloudflare.com

# Indexing Config
BATCH_SIZE=64
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Switch embedding runtime: 'auto' (default), 'cpu', or 'cuda'
EMBEDDING_DEVICE=auto
