# supportLegal - Environment Configuration

# LLM Keys (replace with real values in a private .env file or secret store)
GEMINI_API_KEY=
HUGGINGFACE_TOKEN=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Database
QDRANT_HOST=qdrant
QDRANT_PORT=6334
# Optional fallback only; canonical production contract uses QDRANT_HOST/QDRANT_PORT.
QDRANT_URL=
SQLITE_DB_PATH=legal_poc.db

# Settings
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EMBEDDING_MODEL_NAME=bkai-foundation-models/vietnamese-bi-encoder
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/legal-api.jsonl
CLASSIFIER_PROVIDER=deepseek
CLASSIFIER_FALLBACK_PROVIDER=gemini
CLASSIFIER_MODEL=deepseek-chat
CLASSIFIER_PROVIDER_TIMEOUT=20
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen-14b-chat

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://cent-indianapolis-towers-dad.trycloudflare.com

# Indexing Config
BATCH_SIZE=64
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Switch embedding runtime: 'auto' (default), 'cpu', or 'cuda'
EMBEDDING_DEVICE=auto
